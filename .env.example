# GymBrain local development example
# Copy this file to .env only for local development.
# Do not use these values for Railway production.

# PostgreSQL
CONNECTION_STRING=Host=localhost;Port=5432;Database=gymbrain;Username=gymbrain;Password=replace-local-password

# Redis
REDIS_CONNECTION=localhost:6379

# JWT
JWT_SECRET=replace-with-a-local-dev-secret-minimum-32-characters

# AES-256 Vault key (generate a real base64 32-byte value)
VAULT_ENCRYPTION_KEY=replace-with-base64-32-byte-key
