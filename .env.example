# ===================================
# GymBrain Environment Variables
# ===================================
# Copy this file to .env and fill in real values.
# NEVER commit the .env file (it's in .gitignore).

# PostgreSQL
POSTGRES_PASSWORD=your_strong_password_here
CONNECTION_STRING=Host=localhost;Port=5432;Database=gymbrain;Username=gymbrain;Password=your_strong_password_here

# Redis
REDIS_CONNECTION=localhost:6379

# JWT (REQUIRED — generate a strong random key, minimum 32 characters)
JWT_SECRET=your-jwt-secret-minimum-32-characters-long

# AES-256 Vault (REQUIRED — generate with: openssl rand -base64 32)
VAULT_ENCRYPTION_KEY=your-base64-encoded-32-byte-key-here
